extends: default

rules:
  trailing-spaces: enable

  key-duplicates: enable # Catches duplicate keys
  empty-values: enable # Catches keys without values
  octal-values: # Prevents 0o755-style values being misread as octal
    forbid-implicit-octal: true
    forbid-explicit-octal: false

  new-line-at-end-of-file: enable # Avoids diff noise in git
  new-lines:
    type: unix # Enforces LF, good if editing across machines

  empty-lines:
    max: 2 # You use blank lines for section separation, so stay loose
    max-start: 0
    max-end: 1

  comments:
    min-spaces-from-content: 1 # Brings ymllint inline with prettier for formatting
    require-starting-space: true # Enforces `# comment` not `#comment`

  # Disable formatting noise
  indentation: disable
  brackets: disable
  comments-indentation: disable
  line-length: disable
  document-start: disable
  truthy: disable
